# Lumi prototype — model configuration
#
# 1) Free Google Gemini key (default provider). Get one at:
#    https://aistudio.google.com/apikey   (no credit card)
GOOGLE_GENERATIVE_AI_API_KEY=

# 2) Optional: choose the model as provider:model. Default below.
#    To swap providers later, install @ai-sdk/<provider>, add a case in
#    lib/ai/model.ts, set this var + that provider's key.
# LUMI_MODEL=google:gemini-2.5-flash

# 3) Upstash Redis — persists prototype todos across devices.
#    Provisioned via Vercel Marketplace (Storage tab in project settings).
#    These vars are auto-added by Vercel when the store is connected to the project.
#    Run `vercel env pull .env.local` after connecting to get them locally.
KV_REST_API_URL=
KV_REST_API_TOKEN=
